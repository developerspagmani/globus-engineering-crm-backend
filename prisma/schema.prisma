model AuditLog {
  id         String   @id @db.VarChar(50)
  action     String   @db.VarChar(100)
  entity     String   @db.VarChar(100)
  entity_id  String   @db.VarChar(100)
  details    String?  @db.Text
  user_id    String   @db.VarChar(50)
  user_name  String   @db.VarChar(255)
  company_id String?  @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@map("app_audit_logs")
}

model InvoiceReminder {
  id        String        @id @default(cuid())
  invoiceId Int
  companyId String        @db.VarChar(50)
  enabled   Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  invoice LegacyInvoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  company Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, companyId])
  @@map("invoice_reminders")
}


model EmailLog {
  id             String   @id @default(cuid())
  invoiceId      Int
  customerId     Int
  reminderType   String
  emailSent      DateTime
  recipientEmail String
  status         String
  errorMessage   String?
  createdAt      DateTime @default(now())

  // Relations
  invoice  LegacyInvoice?  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  customer LegacyCustomer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("email_logs")
}

