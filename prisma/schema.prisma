}

model tbl_map {
  id  Int    @id @default(autoincrement())
  lat Float? @db.Float
  lng Float? @db.Float
}

model tbl_package {
  id          Int     @id @default(autoincrement())
  description String? @db.Text
}

model tbl_process {
  id      Int     @id @default(autoincrement())
  process String? @db.VarChar(200)
}

model tbl_social_links {
  id           Int     @id @default(autoincrement())
  name         String? @db.VarChar(100)
  fa_icon_name String? @db.VarChar(100)
  links        String? @db.Text
}

model tbl_vendor {
  id              Int     @id @default(autoincrement())
  customer_name   String? @db.VarChar(200)
  street1         String? @db.VarChar(250)
  street2         String? @db.VarChar(250)
  city            String? @db.VarChar(150)
