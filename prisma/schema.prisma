  popular_dive_destination String? @default("No") @db.VarChar(100)
}

model dive_center {
  dive_center_id      Int     @id @default(autoincrement())
  center_name         String? @db.VarChar(250)
  address1            String? @db.VarChar(250)
  address2            String? @db.VarChar(250)
  city                String? @db.VarChar(50)
  state               String? @db.VarChar(75)
  country_id          Int?
  island_id           Int?
  contact_person_name String? @db.VarChar(250)
  contact_no          BigInt?
  email_id            String? @db.VarChar(250)
  center_image        String? @db.VarChar(250)
}

model employee {
  id     Int     @id @default(autoincrement())
  name   String? @db.VarChar(50)
  gender String? @db.Char(20)
  photo  String? @db.Text
}

model product {
  product_id          Int     @id @default(autoincrement())
  product_name        String? @db.VarChar(60)
  product_image       String? @db.VarChar(250)
  price               Float?
  product_description String? @db.Text
}

model special_offer {
  special_offer_id     Int     @id @default(autoincrement())
  offer_image          String? @db.VarChar(250)
  offer_period         String? @db.VarChar(20)
  price                Float?
  starting_place_id    Int?
  destination_place_id Int?
  start_km             String? @db.VarChar(50)
  note                 String? @db.Text
  dive_center_id       Int?
}

model tbl_country {
  country_id   Int     @id @default(autoincrement())
  country_name String? @db.VarChar(150)
}

model tbl_courses {
  id          Int     @id @default(autoincrement())
  description String? @db.Text
}

model tbl_fundive {
  id          Int     @id @default(autoincrement())
  description String? @db.Text
}

model tbl_generalinfo {
  id          Int     @id @default(autoincrement())
  description String? @db.Text
}

model tbl_help {
  id          Int     @id @default(autoincrement())
  description String? @db.Text
}

model tbl_invoice_item {
  id             Int     @id @default(autoincrement())
  invoice_no     Int?
  item_id        Int?
  process_id     Int?
  qty            Int?    @default(0)
  wop_qty        Int?    @default(0)
  price          Float?
  item_total     Float?
  status         String? @default("BILLED") @db.VarChar(50)
  inward_item_no Int?
